generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Room {
  id        String   @id @default(cuid())
  roomNo    String   @unique
  floor     Int      @default(1)
  type      String   @default("Single") // Single, Double, Triple
  baseRent  Float    @default(5000) // Room's default rent — resets to this on checkout
  monthlyRent Float   @default(5000) // Current active rent — can be changed via rent update for current guest
  maintenanceCharge Float @default(0) // Monthly maintenance charge for this room
  status    String   @default("Vacant") // Vacant, Occupied, Maintenance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guests       Guest[]
  bills        Bill[]
  rentChanges  RentChange[]
}

model RentChange {
  id            String   @id @default(cuid())
  roomId        String
  oldRent       Float
  newRent       Float
  effectiveDate DateTime // Date from which new rent applies
  reason        String   @default("")
  createdAt     DateTime @default(now())

  room          Room     @relation(fields: [roomId], references: [id])
}

model Guest {
  id              String   @id @default(cuid())
  name            String
  nameHindi       String   @default("")
  phone           String   @default("")
  aadhaarNo       String   @default("")
  emergencyContact String  @default("")
  occupation      String   @default("")
  workLocation    String   @default("")
  totalMembers    Int      @default(1)
  photoLink       String   @default("")
  roomId          String
  checkInDate     DateTime
  checkOutDate    DateTime?
  billingCycleDate Int     // The date of month when billing triggers (same as check-in day)
  status          String   @default("Live") // Live, Checked-out
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  room            Room     @relation(fields: [roomId], references: [id])
  securityDeposit SecurityDeposit?
  bills           Bill[]
  electricityReadings ElectricityReading[]
  memberHistory   MemberHistory[]
}

model SecurityDeposit {
  id          String   @id @default(cuid())
  guestId     String   @unique
  amount      Float
  status      String   @default("Held") // Held, Refunded, Partially-Refunded, Adjusted
  deductedAmount Float  @default(0)
  refundDate  DateTime?
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  guest       Guest    @relation(fields: [guestId], references: [id])
}

model Bill {
  id               String   @id @default(cuid())
  guestId          String
  roomId           String
  billingMonth     Int      // 1-12
  billingYear      Int      // e.g., 2025
  rentAmount       Float
  maintenanceCharge Float   @default(0) // Monthly maintenance charge at the time of billing
  electricityCharge Float   @default(0)
  previousReading  Float   @default(0)
  currentReading   Float   @default(0)
  unitsConsumed    Float   @default(0)
  ratePerUnit      Float   @default(10)
  minChargePolicy  String   @default("FULL_MONTH") // FULL_MONTH, PRO_RATA
  manualAdjustment Float   @default(0) // positive = extra charge, negative = discount
  adjustmentReason String   @default("")
  isCustomBill     Boolean  @default(false)
  customTotal      Float?
  totalAmount      Float
  paidAmount      Float    @default(0) // Amount paid so far (for partial payments)
  dueDate          DateTime
  paidDate        DateTime?
  status          String   @default("Unpaid") // Unpaid, Paid, Overdue, Partially-Paid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  guest           Guest    @relation(fields: [guestId], references: [id])
  room            Room     @relation(fields: [roomId], references: [id])
}

model ElectricityReading {
  id          String   @id @default(cuid())
  guestId     String
  reading     Float
  readingDate DateTime @default(now())
  createdAt   DateTime @default(now())

  guest       Guest    @relation(fields: [guestId], references: [id])
}

model MemberHistory {
  id            String   @id @default(cuid())
  guestId       String
  oldMemberCount Int
  newMemberCount Int
  effectiveDate DateTime // Date from which new member count applies
  reason        String   @default("") // e.g. "1 member left"
  createdAt     DateTime @default(now())

  guest         Guest    @relation(fields: [guestId], references: [id])
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed password
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
